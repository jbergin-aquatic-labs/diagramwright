{
  "name": "diagramwright-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server + local sync bridge for Diagramwright. Lets agents read and edit the live diagram while a user collaborates in the browser.",
  "bin": {
    "diagramwright-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
